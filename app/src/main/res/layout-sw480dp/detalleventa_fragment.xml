<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layout_margin="3dp"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <RelativeLayout
        android:id="@+id/layAcciones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#7070f0"
        android:padding="5dp"
        >
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivEliminar"
            android:layout_width="@dimen/icon_cv_size"
            android:layout_height="@dimen/icon_cv_size"
            android:background="@drawable/bar_eliminar"
            android:layout_alignParentLeft="true"
            android:layout_marginHorizontal="5dp"
            />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivMueveSubmesa"
            android:layout_width="@dimen/icon_cv_size"
            android:layout_height="@dimen/icon_cv_size"
            android:background="@drawable/bar_submesa"
            android:layout_toRightOf="@id/ivEliminar"
            android:layout_marginHorizontal="5dp"
            />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivAceptar"
            android:layout_width="@dimen/icon_cv_size"
            android:layout_height="@dimen/icon_cv_size"
            android:background="@drawable/aceptar"
            android:layout_alignParentRight="true"
            android:layout_marginHorizontal="5dp"
            />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivCancelar"
            android:layout_width="@dimen/icon_cv_size"
            android:layout_height="@dimen/icon_cv_size"
            android:background="@drawable/cancelar"
            android:layout_toLeftOf="@id/ivAceptar"
            android:layout_marginHorizontal="10sp"
            />


    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/layDatos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="6"
        android:orientation="vertical">

        <RelativeLayout
            android:id="@+id/layDatosUds"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/layUds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="3dp"
                android:orientation="horizontal"
                android:layout_alignParentTop="true">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivUdMenos"
                    android:layout_width="@dimen/icon_cv_size"
                    android:layout_height="@dimen/icon_cv_size"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/quitar" />

                <EditText
                    android:id="@+id/etUnidades"
                    android:layout_width="wrap_content"
                    android:maxWidth="@dimen/vc_text_maxwidth2"
                    android:layout_height="@dimen/icon_cv_size"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:background="@color/textoAzul"
                    android:gravity="right|center_vertical"
                    android:minWidth="@dimen/vc_text_minwidth2"
                    android:paddingHorizontal="10dp"
                    android:text="2"
                    android:textColor="@color/textoBlanco"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_titulo"/>

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivUdMas"
                    android:layout_width="@dimen/icon_cv_size"
                    android:layout_height="@dimen/icon_cv_size"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/anadir" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:gravity="left"
                    android:padding="10dp"
                    android:text="UD"
                    android:textColor="@color/textoAzul"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_titulo"/>


            </LinearLayout>

            <LinearLayout
                android:id="@+id/layOrden"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_below="@id/layUds"
                android:layout_marginVertical="5dp"
                android:layout_alignParentLeft="true"
                android:layout_alignRight="@+id/layUds"
                >
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivBebida"
                    android:layout_width="@dimen/icon_small_size"
                    android:layout_height="@dimen/icon_small_size"
                    android:background="@drawable/bar_bebida_sel"
                    android:layout_gravity="left"
                    android:layout_marginRight="5dp"
                    />
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivEntrante"
                    android:layout_width="@dimen/icon_small_size"
                    android:layout_height="@dimen/icon_small_size"
                    android:background="@drawable/bar_entrante1"
                    android:layout_gravity="left"
                    android:layout_marginRight="5dp"
                    />
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivPrimero"
                    android:layout_width="@dimen/icon_small_size"
                    android:layout_height="@dimen/icon_small_size"
                    android:background="@drawable/bar_primero1"
                    android:layout_gravity="left"
                    android:layout_marginRight="5dp"
                    />
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivSegundo"
                    android:layout_width="@dimen/icon_small_size"
                    android:layout_height="@dimen/icon_small_size"
                    android:background="@drawable/bar_comida1"
                    android:layout_gravity="left"
                    android:layout_marginRight="5dp"
                    />
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivPostre"
                    android:layout_width="@dimen/icon_small_size"
                    android:layout_height="@dimen/icon_small_size"
                    android:background="@drawable/bar_postre1"
                    android:layout_gravity="left"
                    android:layout_marginRight="5dp"
                    />
            </LinearLayout>


            <LinearLayout
                android:id="@+id/layDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/layOrden"
                android:layout_alignRight="@+id/layUds"
                android:layout_alignParentLeft="true"
                android:layout_marginTop="10dp"
                android:layout_marginLeft="3dp"
                >

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivTipo"
                    android:layout_width="@dimen/icon_cv_size"
                    android:layout_height="@dimen/icon_cv_size"
                    android:background="@drawable/navmenu_bebida"
                    android:layout_gravity="center_vertical"
                    />

                <TextView
                    android:id="@+id/tvDescripcion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/icon_cv_size"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:layout_weight="4"
                    android:background="@color/textoAzul"
                    android:gravity="center"
                    android:minWidth="@dimen/vc_text_minwidth"
                    android:padding="5dp"
                    android:text="COCACOLA"
                    android:textColor="@color/textoBlanco"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_titulo"
                    />
            </LinearLayout>


            <LinearLayout
                android:id="@+id/layPrecio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/layDesc"
                android:layout_alignRight="@id/layUds"
                android:layout_alignParentLeft="true"
                android:layout_marginTop="10dp"
                android:layout_marginLeft="3dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:gravity="left"
                    android:padding="2dp"
                    android:text="PVP"
                    android:textColor="@color/textoAzul"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_titulo2"
                    android:layout_gravity="center_vertical"/>

                <EditText
                    android:id="@+id/etPrecio"
                    android:layout_width="wrap_content"
                    android:maxWidth="100dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="5dp"
                    android:background="@color/textoAzul"
                    android:gravity="right|center_vertical"
                    android:minWidth="60dp"
                    android:padding="2dp"
                    android:text="1,20"
                    android:textColor="@color/textoBlanco"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_titulo"
                    android:layout_gravity="center_vertical"
                    android:enabled="false"
                    android:inputType="numberDecimal"
                    android:selectAllOnFocus="true"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:gravity="left"
                    android:padding="2dp"
                    android:text="€"
                    android:textColor="@color/textoAzul"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_titulo"
                    android:layout_gravity="center_vertical"/>

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivCalculaPrecio"
                    android:layout_width="@dimen/icon_cv_size"
                    android:layout_height="@dimen/icon_cv_size"
                    android:background="@drawable/bar_calcular"
                    android:layout_marginLeft="20dp"
                    />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:gravity="left"
                    android:padding="2dp"
                    android:text="TOT"
                    android:textColor="@color/textoAzul"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_titulo2"
                    android:layout_gravity="center_vertical"/>

                <TextView
                    android:id="@+id/tvTotal"
                    android:layout_width="wrap_content"
                    android:maxWidth="100dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="5dp"
                    android:background="@color/textoAzul"
                    android:gravity="right|center_vertical"
                    android:minWidth="60dp"
                    android:padding="2dp"
                    android:text="12,80€"
                    android:textColor="@color/textoBlanco"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_titulo"
                    android:layout_gravity="center_vertical"
                    />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/layPrecio"
                android:layout_alignRight="@id/layUds"
                android:layout_alignParentLeft="true"
                android:layout_marginTop="10dp">


                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivHH"
                    android:layout_width="@dimen/icon_cv_size"
                    android:layout_height="@dimen/icon_cv_size"
                    android:background="@drawable/bar_happy_hour" />

                <TextView
                    android:id="@+id/tvHH"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="10dp"
                    android:text="HappyHour"
                    android:textColor="@color/textoAzul"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_titulo"
                    />



            </LinearLayout>

        </RelativeLayout>

        <LinearLayout
            android:id="@+id/layNota"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/layDatosUds"
            android:layout_alignParentRight="true"
            android:layout_alignParentLeft="true"
            android:layout_marginHorizontal="8dp"
            android:layout_marginTop="10dp"
            android:background="@color/fondoFrgDetalleNota1"
            android:orientation="vertical"
            android:padding="8dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="@color/fondoFrgDetalleNota1"
                android:orientation="horizontal"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tvExtraNotas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:text="Extras y notas"
                    android:textColor="@color/textoAzul"
                    android:textSize="@dimen/text_titulo"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivExtras"
                    android:layout_width="@dimen/icon_cv_size"
                    android:layout_height="@dimen/icon_cv_size"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@android:drawable/ic_menu_edit" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvResumenNotas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"
                android:background="@color/fondoFrgDetalleNota2"
                android:minHeight="100dp"
                android:nestedScrollingEnabled="false"
                android:padding="8dp"
                android:scrollbars="vertical" />


        </LinearLayout>

    </RelativeLayout>



</LinearLayout>



