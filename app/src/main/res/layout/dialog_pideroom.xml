<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/layNewRoom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">



    </LinearLayout>


    <LinearLayout
        android:id="@+id/layNewPax"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="left"
            android:layout_marginHorizontal="20dp"
            android:layout_marginVertical="10dp"
            android:text="@string/dialog_strRoomAñadir"
            android:textColor="@color/textoAzul"
            android:textSize="@dimen/text_titulo"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:layout_marginLeft="20dp">


            <EditText
                android:id="@+id/etRoom"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:paddingVertical="15dp"
                android:text=""
                android:hint="@string/dialog_strHintHabitacion"
                android:textStyle="bold"
                android:textSize="@dimen/text_titulo"
                android:textColor="@color/colorAccent"
                android:gravity="center_horizontal"
                android:selectAllOnFocus="true"
                android:inputType="text"

                />


            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivExterno"
                android:layout_width="@dimen/icon_cv_size"
                android:layout_height="@dimen/icon_cv_size"
                android:layout_alignParentRight="true"
                android:layout_marginLeft="5dp"
                android:background="@drawable/bar_externo" />

        </LinearLayout>



    </LinearLayout>


</LinearLayout>