<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/laySel"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="3dp"
    android:background="@color/transparente"
    >

    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/cv"
        app:cardCornerRadius="15dp"
        app:cardElevation="15dp"
        >

        <LinearLayout
            android:id="@+id/fondo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:background="@color/cvBorde"
            android:orientation="vertical"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@color/cvFondo"
                android:layout_gravity="top"
                android:padding="5dp"
                android:paddingRight="10dp"
                >
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivMax"
                    android:layout_width="@dimen/icon_cv_size"
                    android:layout_height="@dimen/icon_cv_size"
                    android:background="@drawable/bar_user"
                    android:layout_gravity="center_horizontal"
                    />

                <TextView
                    android:layout_width="wrap_content"
                    android:minWidth="@dimen/vc_text_minwidth"
                    android:layout_height="wrap_content"
                    android:id="@+id/nombre"
                    android:textSize="@dimen/text_titulo"
                    android:textColor="@color/textoAzul"
                    android:textStyle="bold"
                    android:text="usuario 1"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal"
                    />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layClave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/cvFondo"
                android:layout_gravity="bottom"
                android:padding="10dp"
                android:visibility="gone"
                >

                <EditText
                    android:layout_width="wrap_content"
                    android:minWidth="@dimen/vc_text_minwidth2"
                    android:layout_height="wrap_content"
                    android:id="@+id/clave"
                    android:textSize="@dimen/text_titulo"
                    android:textColor="@color/textoAzul"
                    android:textStyle="bold"
                    android:text=""
                    android:inputType="text|textPassword"
                    android:imeOptions="actionDone"
                    android:hint="@string/hint_clave"
                    android:gravity="center"
                    android:layout_gravity="center_vertical"
                    />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivCancelar"
                    android:layout_width="@dimen/icon_cv_size"
                    android:layout_height="@dimen/icon_cv_size"
                    android:background="@drawable/cancelar"
                    android:layout_gravity="center_vertical|center_horizontal"
                    android:layout_marginLeft="10dp"
                    />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivAceptar"
                    android:layout_width="@dimen/icon_cv_size"
                    android:layout_height="@dimen/icon_cv_size"
                    android:background="@drawable/aceptar"
                    android:layout_gravity="center_vertical|center_horizontal"
                    android:layout_marginLeft="10dp"
                    />

            </LinearLayout>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>