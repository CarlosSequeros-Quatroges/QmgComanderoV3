<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/laySel"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="3dp"
    android:background="@color/transparente"
    >

    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/cv"
        app:cardCornerRadius="15dp"
        app:cardElevation="15dp"
        >


        <FrameLayout
            android:id="@+id/fondo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:background="@color/cvBorde"
            >


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@color/cvFondo"
                android:alpha="1"
                android:layout_gravity="center_vertical"
                android:padding="2dp"
                >

                 <LinearLayout
                    android:layout_width="@dimen/vc_text_maxwidth2"
                    android:minWidth="@dimen/vc_text_minwidth2"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivOrden_platos"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical|left"
                        android:background="@drawable/navmenu_bebida" />


                    <TextView
                        android:id="@+id/descripcion"
                        android:layout_width="@dimen/vc_text_maxwidth2"
                        android:minWidth="@dimen/vc_text_minwidth2"
                        android:layout_height="@dimen/vc_text_maxHeight"
                        android:gravity="center"
                        android:maxLines="2"
                        android:minLines="1"
                        android:text="COCACOLA "
                        android:textColor="@color/textoAzul"
                        android:textSize="@dimen/text_titulo2"
                        android:textStyle="bold" />

                 </LinearLayout>

                <LinearLayout
                    android:layout_width="@dimen/vc_text_maxwidth2"
                    android:minWidth="@dimen/vc_text_minwidth2"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivHH"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/navmenu_happy_hour"
                        android:layout_gravity="center_vertical"
                        />


                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:id="@+id/precio"
                        android:layout_alignEnd="@+id/imagen"
                        android:layout_below="@+id/descripcion"
                        android:textStyle="bold"
                        android:text="1,20€"
                        android:textColor="@color/textoAzul"
                        android:gravity="right"
                        android:layout_gravity="center_vertical"
                        android:layout_weight="1"
                        />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>