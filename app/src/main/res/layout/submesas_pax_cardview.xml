<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@color/transparente"
    android:padding="3dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="5dp"
        app:cardElevation="5dp">

        <LinearLayout
            android:id="@+id/laySel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|center_vertical"
            android:orientation="vertical"
            android:padding="3dp">

            <LinearLayout
                android:id="@+id/fondo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/mesaLibre"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="60dp"
                    android:layout_gravity="center_vertical"
                    android:alpha="1"
                    android:orientation="horizontal"
                    android:padding="3dp">

                    <TextView
                        android:id="@+id/numero"
                        android:layout_width="20dp"
                        android:layout_height="match_parent"
                        android:text="2"
                        android:textColor="@color/textoBlanco"
                        android:gravity="center"
                        android:layout_gravity="center_horizontal"
                        android:textSize="@dimen/text_actionbar"
                        android:textStyle="bold"
                        />

                    <LinearLayout
                        android:layout_width="2dp"
                        android:layout_height="match_parent"
                        android:background="@color/textoAzul"
                        android:layout_marginRight="5dp"/>

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivPaxDown"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center_vertical"
                        android:background="@drawable/quitar" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:layout_marginHorizontal="10dp">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/ivPax"
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_gravity="center_horizontal"
                            android:background="@drawable/bar_pax" />

                            <TextView
                                android:id="@+id/pax"
                                android:layout_width="25dp"
                                android:layout_height="match_parent"
                                android:layout_gravity="center_horizontal"
                                android:text="3"
                                android:gravity="center"
                                android:textColor="@color/textoBlanco"
                                android:textSize="@dimen/text_actionbar"
                                android:textStyle="bold" />

                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivPaxUp"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center_vertical"
                        android:background="@drawable/anadir" />


                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="60dp"
                    android:layout_gravity="center_vertical"
                    android:alpha="1"
                    android:orientation="horizontal"
                    android:padding="3dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center_vertical"
                        android:background="@drawable/bar_room" />

                    <EditText
                        android:id="@+id/etRoom"
                        android:layout_width="80dp"
                        android:layout_height="48dp"
                        android:layout_marginHorizontal="20dp"
                        android:paddingVertical="15dp"
                        android:text="12345"
                        android:hint="@string/dialog_strHintHabitacion"
                        android:textStyle="bold"
                        android:textSize="@dimen/text_titulo"
                        android:textColor="@color/textoBlanco"
                        android:gravity="center_horizontal"
                        android:selectAllOnFocus="true"
                        android:inputType="number"

                        />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>