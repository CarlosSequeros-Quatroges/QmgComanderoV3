<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@color/transparente"
    android:padding="3dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="5dp"
        app:cardElevation="5dp">

        <LinearLayout
            android:id="@+id/laySel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:padding="3dp">

            <LinearLayout
                android:id="@+id/fondo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/mesaLibre"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minWidth="@dimen/vc_text_minwidth"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="6"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center_vertical"
                            android:alpha="1"
                            android:orientation="horizontal"
                            android:padding="3dp">

                            <androidx.appcompat.widget.AppCompatImageView
                                android:id="@+id/ivMesa"
                                android:layout_width="@dimen/icon_small_size"
                                android:layout_height="@dimen/icon_small_size"
                                android:layout_gravity="left"
                                android:background="@drawable/bar_mesa" />

                            <TextView
                                android:id="@+id/numero"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:layout_marginLeft="5dp"
                                android:gravity="center"
                                android:text="2"
                                android:textColor="@color/textoBlanco"
                                android:textSize="@dimen/text_actionbar"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/descripcion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:layout_marginLeft="5dp"
                                android:gravity="center"
                                android:text="Mesa 2"
                                android:textColor="@color/textoBlanco"
                                android:textSize="@dimen/text_actionbar"
                                android:textStyle="bold" />

                            <androidx.appcompat.widget.AppCompatImageView
                                android:id="@+id/ivEstado"
                                android:layout_width="@dimen/icon_small_size"
                                android:layout_height="@dimen/icon_small_size"
                                android:background="@drawable/bar_tiquet"
                                android:layout_gravity="center_vertical"
                                android:layout_marginLeft="20dp"
                                />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center_vertical"
                            android:alpha="1"
                            android:orientation="horizontal"
                            android:padding="3dp">

                            <androidx.appcompat.widget.AppCompatImageView
                                android:id="@+id/ivPax"
                                android:layout_width="@dimen/icon_small_size"
                                android:layout_height="@dimen/icon_small_size"
                                android:layout_gravity="left|center_vertical"
                                android:background="@drawable/bar_pax" />

                            <TextView
                                android:id="@+id/pax"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:layout_marginLeft="5dp"
                                android:gravity="center"
                                android:text="3"
                                android:textColor="@color/textoBlanco"
                                android:textSize="@dimen/text_actionbar"
                                android:textStyle="bold" />

                            <androidx.appcompat.widget.AppCompatImageView
                                android:id="@+id/ivRoom"
                                android:layout_width="@dimen/icon_small_size"
                                android:layout_height="@dimen/icon_small_size"
                                android:background="@drawable/bar_room"
                                android:layout_gravity="center_vertical"
                                android:layout_marginLeft="20dp"
                                />

                            <TextView
                                android:id="@+id/room"
                                android:layout_width="60dp"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:layout_marginLeft="5dp"
                                android:gravity="center"
                                android:text="103\n104\n104"
                                android:textColor="@color/textoBlanco"
                                android:minLines="3"
                                android:maxLines="5"
                                android:textSize="@dimen/text_actionbar"
                                android:textStyle="bold" />


                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="6">

                            <TextView
                                android:id="@+id/importe"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="3dp"
                                android:gravity="left"
                                android:text="123.14€"
                                android:textColor="@color/textoBlanco"
                                android:textSize="@dimen/text_actionbar"
                                android:textStyle="bold"
                                android:textAlignment="center"
                                android:layout_gravity="center_vertical"
                                />

                        </LinearLayout>

                    </LinearLayout>



                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layDatos"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.8"
                android:background="@android:color/background_light"
                android:orientation="vertical"
                android:padding="10dp"
                android:visibility="visible"
                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <EditText
                        android:id="@+id/etRoom"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:hint="@string/hint_room"
                        android:imeOptions="actionDone"
                        android:inputType="text"
                        android:text=""
                        android:maxLength="5"
                        android:textColor="@color/textoAzul"
                        android:textSize="@dimen/text_titulo"
                        android:textStyle="bold"
                        android:layout_gravity="center_horizontal"
                        android:paddingHorizontal="5dp"
                        android:layout_weight="10"
                        />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivExterno"
                        android:layout_width="@dimen/icon_cv_size"
                        android:layout_height="@dimen/icon_cv_size"
                        android:layout_alignParentRight="true"
                        android:layout_marginLeft="5dp"
                        android:background="@drawable/bar_externo" />

                </LinearLayout>

                <EditText
                        android:id="@+id/etPax"
                        android:layout_width="@dimen/vc_text_minwidth"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:hint="@string/hint_pax"
                        android:imeOptions="actionDone"
                        android:inputType="number"
                        android:text=""
                        android:textColor="@color/textoAzul"
                        android:textSize="@dimen/text_titulo"
                        android:textStyle="bold"
                        android:layout_gravity="center_horizontal"
                        android:paddingHorizontal="5dp"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">


                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivCancelar"
                        android:layout_width="@dimen/icon_cv_size"
                        android:layout_height="@dimen/icon_cv_size"
                        android:layout_alignParentLeft="true"
                        android:layout_marginRight="5dp"
                        android:background="@drawable/cancelar" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivAceptar"
                        android:layout_width="@dimen/icon_cv_size"
                        android:layout_height="@dimen/icon_cv_size"
                        android:layout_alignParentRight="true"
                        android:layout_marginLeft="5dp"
                        android:background="@drawable/aceptar" />
                </RelativeLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>