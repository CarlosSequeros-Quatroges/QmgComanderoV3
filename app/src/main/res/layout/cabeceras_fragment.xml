<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layCons"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <androidx.appcompat.widget.SearchView
        android:id="@+id/svCabeceras"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:layout_editor_absoluteX="8dp"
        tools:layout_editor_absoluteY="315dp"
        android:inputType="text"
        android:background="@color/cvFondo"
        android:visibility="visible"
        />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/textoAzul"
        android:orientation="horizontal"
        />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/flMin"
            android:layout_width="@dimen/icon_small_size"
            android:layout_height="wrap_content"
            >

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivMin"
                android:layout_width="@dimen/icon_small_size"
                android:layout_height="@dimen/icon_small_size"
                android:background="@drawable/arrow"
                android:layout_gravity="top"
                android:rotation="90"
                android:alpha=".4"
                />

        </FrameLayout>


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCabeceras"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:layout_constraintStart_toEndOf="@id/flMin"
            app:layout_constraintEnd_toStartOf="@id/flMax"
            app:layout_constraintTop_toBottomOf="@id/svCabeceras"
            app:layout_constraintBottom_toBottomOf="@id/layCons"
            android:paddingHorizontal="2dp"
            tools:itemCount="10"
            tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/cabeceras_cardview"
            tools:orientation="horizontal"
            tools:spanCount="2"
            android:layout_weight="50"
            />

            <LinearLayout
                android:id="@+id/flMax"
                android:layout_width="@dimen/icon_size"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:orientation="vertical"
                >

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivMax"
                    android:layout_width="@dimen/icon_small_size"
                    android:layout_height="@dimen/icon_small_size"
                    android:layout_gravity="top|right"
                    android:layout_marginBottom="5dp"
                    android:alpha=".4"
                    android:background="@drawable/arrow"
                    android:rotation="-90" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivVerMas"
                    android:layout_width="@dimen/icon_size"
                    android:layout_height="@dimen/icon_size"
                    android:layout_gravity="bottom"
                    android:background="@drawable/arrow"
                    android:rotation="0" />


            </LinearLayout>

    </LinearLayout>

</LinearLayout>


