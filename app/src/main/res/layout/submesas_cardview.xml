<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@color/transparente"
    android:padding="3dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="5dp"
        app:cardElevation="5dp">

        <LinearLayout
            android:id="@+id/laySel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|center_vertical"
            android:orientation="vertical"
            android:padding="3dp">

            <LinearLayout
                android:id="@+id/fondo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/mesaLibre"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="@dimen/vc_text_minwidth3"
                    android:layout_height="@dimen/vc_text_maxHeight3"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/numero"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:text="2"
                        android:textColor="@color/textoBlanco"
                        android:gravity="center"
                        android:layout_gravity="center_horizontal"
                        android:textSize="@dimen/text_actionbar"
                        android:textStyle="bold"
                        android:layout_weight="1"
                        />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivErrTransmision"
                        android:layout_width="0dp"
                        android:layout_height="24dp"
                        android:background="@drawable/error"
                        android:alpha=".8"
                        android:layout_marginRight="5dp"
                        android:layout_gravity="center_vertical"
                        android:layout_weight="1"
                        android:visibility="gone"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>