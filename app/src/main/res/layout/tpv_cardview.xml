<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/laySel"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@color/transparente"
    android:padding="3dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="15dp"
        app:cardElevation="15dp">

        <FrameLayout
            android:id="@+id/fondo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/cvBorde"
            android:padding="5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/cvFondo"
                android:orientation="vertical"
                android:padding="5dp">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivMax"
                    android:layout_width="@dimen/icon_cv_size"
                    android:layout_height="@dimen/icon_cv_size"
                    android:layout_gravity="center_vertical|center_horizontal"
                    android:background="@drawable/bar_tpv" />

                <TextView
                    android:id="@+id/descripcion"
                    android:layout_width="wrap_content"
                    android:minWidth="@dimen/vc_text_minwidth"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="BAR PISCINA"
                    android:textColor="@color/textoAzul"
                    android:textSize="@dimen/text_titulo"
                    android:textStyle="bold" />

            </LinearLayout>
        </FrameLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>