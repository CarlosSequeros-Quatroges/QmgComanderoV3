<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/laySel"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="3dp"
    android:background="@color/transparente">

    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/cv"
        app:cardCornerRadius="15dp"
        app:cardElevation="15dp">

        <FrameLayout
            android:id="@+id/fondo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/cvBorde"
            android:padding="5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@color/cvFondo"
                android:alpha="1"
                android:layout_gravity="center_vertical"
                android:padding="5dp"
                >

                <TextView
                    android:id="@+id/descripcion"
                    android:layout_width="@dimen/vc_text_maxwidth2"
                    android:minWidth="@dimen/vc_text_minwidth2"
                    android:layout_height="@dimen/vc_text_maxHeight"
                    android:gravity="center"
                    android:maxLines="2"
                    android:minLines="1"
                    android:textSize="@dimen/text_titulo2"
                    android:textStyle="bold"
                    android:text="COCACOLA  cero maxima "
                    android:textColor="@color/textoAzul"
                    />

            </LinearLayout>

        </FrameLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>