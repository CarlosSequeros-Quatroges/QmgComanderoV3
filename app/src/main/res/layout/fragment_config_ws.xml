<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:orientation="vertical"
        >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/config_strServidorWeb"
            android:textColor="@color/textoAzul"
            android:textSize="@dimen/text_titulo"
            android:layout_marginTop="10dp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etURL"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="70dp"
            android:inputType="textUri"
            android:textColor="@color/colorAccent"
            android:hint="@string/config_strServidorWeb"
            android:textSize="@dimen/text_titulo"/>



        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/config_strAPI"
            android:textColor="@color/textoAzul"
            android:textSize="@dimen/text_titulo"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etApi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="70dp"
            android:layout_marginBottom="5dp"
            android:ems="10"
            android:hint="@string/config_strAPI"
            android:inputType="text"
            android:textColor="@color/colorAccent"
            android:textSize="@dimen/text_titulo"/>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/config_strTimeout"
            android:textColor="@color/textoAzul"
            android:textSize="@dimen/text_titulo"
            android:textStyle="bold" />
            />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="5dp"
                android:layout_marginHorizontal="5dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/textoAzul"
                    android:textSize="@dimen/text_titulo"
                    android:text="Con"
                    />

                <EditText
                    android:id="@+id/etConTO"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="1"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="5dp"
                android:layout_marginHorizontal="5dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/textoAzul"
                    android:textSize="@dimen/text_titulo"
                    android:text="RW1"
                    />

                <EditText
                    android:id="@+id/etRW1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="1"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="5dp"
                android:layout_marginHorizontal="5dp">
                >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/textoAzul"
                    android:textSize="@dimen/text_titulo"
                    android:text="RW2"
                    />

                <EditText
                    android:id="@+id/etRW2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="2"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="5dp"
                android:layout_marginHorizontal="5dp">
                >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/textoAzul"
                    android:textSize="@dimen/text_titulo"
                    android:text="RW3"
                    />

                <EditText
                    android:id="@+id/etRW3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="3"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="5dp"
                android:layout_marginHorizontal="5dp">
                >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/textoAzul"
                    android:textSize="@dimen/text_titulo"
                    android:text="RW4"
                    />

                <EditText
                    android:id="@+id/etRW4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="4"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="5dp"
                android:layout_marginHorizontal="5dp">
                >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/textoAzul"
                    android:textSize="@dimen/text_titulo"
                    android:text="RW5"
                    />

                <EditText
                    android:id="@+id/etRW5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="5"/>

            </LinearLayout>


        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="ID Dispositivo"
            android:textColor="@color/textoAzul"
            android:textSize="@dimen/text_titulo"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvUUID"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/colorAccent"
            android:text="jf8jr398u34"
            android:textStyle="bold"
            android:textSize="@dimen/text_titulo"
            android:layout_marginLeft="10dp"
            android:inputType="text" />



    </LinearLayout>


</ScrollView>