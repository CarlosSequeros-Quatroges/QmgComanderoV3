<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layout_margin="10dp"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginVertical="5dp"
        >

        <TextView
            android:id="@+id/tvDescripcion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@color/textoAzul"
            android:gravity="center"
            android:padding="10dp"
            android:text="COCACOLA"
            android:textColor="@color/textoBlanco"
            android:textStyle="bold"
            android:textSize="@dimen/text_titulo2"
            android:layout_weight="8"
            android:layout_marginRight="2dp"
            />

        <TextView
            android:id="@+id/tvCabecera"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@color/colorAccent"
            android:gravity="center"
            android:padding="10dp"
            android:text="(SNACKS)"
            android:textColor="@color/textoBlanco"
            android:textStyle="bold"
            android:textSize="@dimen/text_titulo2"
            android:layout_weight="4"
            />
    </LinearLayout>

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="0,1,2,3"
        >

        <TableRow
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginVertical="5dp"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:gravity="left"
                    android:padding="5dp"
                    android:text="Orden:"
                    android:textColor="@color/textoAzul"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_titulo2"
                    android:layout_gravity="center_vertical" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivOrdenPlato"
                    android:layout_width="@dimen/icon_small_size"
                    android:layout_height="@dimen/icon_small_size"
                    android:background="@drawable/bar_bebida_sel"
                    android:layout_gravity="center_vertical"
                    />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:gravity="left"
                    android:padding="5dp"
                    android:text="B/C:"
                    android:textColor="@color/textoAzul"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_titulo2"
                    android:layout_gravity="center_vertical" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivTipo"
                    android:layout_width="@dimen/icon_cv_size"
                    android:layout_height="@dimen/icon_cv_size"
                    android:background="@drawable/navmenu_bebida"
                    />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:gravity="left"
                    android:padding="2dp"
                    android:text="PVP"
                    android:textColor="@color/textoAzul"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_titulo2"
                    android:layout_gravity="center_vertical"/>

                <TextView
                    android:id="@+id/tvPrecio"
                    android:layout_width="wrap_content"
                    android:maxWidth="100dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="5dp"
                    android:background="@color/colorAccent"
                    android:gravity="right|center_vertical"
                    android:minWidth="60dp"
                    android:padding="2dp"
                    android:text="1,20"
                    android:textColor="@color/textoBlanco"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_titulo"
                    android:layout_gravity="center_vertical"
                    android:enabled="false"
                    android:inputType="numberDecimal"
                    android:selectAllOnFocus="true"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:gravity="left"
                    android:padding="2dp"
                    android:text="€"
                    android:textColor="@color/textoAzul"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_titulo"
                    android:layout_gravity="center_vertical"/>
            </LinearLayout>

        </TableRow>
    </TableLayout>
    <LinearLayout
        android:id="@+id/layNota"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/layDatosUds"
        android:layout_alignParentRight="true"
        android:layout_alignParentLeft="true"
        android:background="@color/fondoFrgDetalleNota1"
        android:orientation="vertical"
        android:padding="5dp"
        android:layout_marginTop="10dp"
        >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:gravity="left"
                android:padding="2dp"
                android:text="Información"
                android:textStyle="bold"
                android:textColor="@color/textoBlanco"
                android:textSize="@dimen/text_titulo2"/>

            <TextView
                android:id="@+id/tvNota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:gravity="left"
                android:minWidth="100dp"
                android:minLines="5"
                android:maxLines="5"
                android:scrollbars="vertical"
                android:fadeScrollbars="false"
                android:padding="10dp"
                android:text="Nota de la pizza sin nada"
                android:textSize="@dimen/text_titulo"
                android:textColor="@color/negro"
                android:background="@color/fondoFrgDetalleNota2"
                android:layout_marginBottom="2dp"
                android:hint="Notas..."
                android:inputType="textMultiLine"
                />

        </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginVertical="5dp"
        >

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@color/textoAzul"
            android:gravity="center"
            android:padding="10dp"
            android:text="Alergenos"
            android:textColor="@color/textoBlanco"
            android:textStyle="bold"
            android:textSize="@dimen/text_titulo"
            android:layout_weight="6"
            android:layout_marginRight="2dp"
            />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@color/textoAzul"
            android:gravity="center"
            android:padding="10dp"
            android:text="Etiquetas"
            android:textColor="@color/textoBlanco"
            android:textStyle="bold"
            android:textSize="@dimen/text_titulo"
            android:layout_weight="6"
            />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginVertical="5dp"
        >

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAlergenos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="0dp"
            android:scrollbars = "vertical"
            android:fadeScrollbars="false"
            tools:itemCount="5"
            tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/filtros_cardview"
            tools:orientation="vertical"
            tools:spanCount="1"
            android:layout_weight="6"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvEtiquetas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="0dp"
            android:scrollbars = "vertical"
            android:fadeScrollbars="false"
            tools:itemCount="5"
            tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/filtros_cardview"
            tools:orientation="vertical"
            tools:spanCount="1"
            android:layout_weight="6"/>

    </LinearLayout>

</LinearLayout>


