<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="es.quatroges.qgestpv_v3.ActivityInicio">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/AppTheme.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:popupTheme="@style/AppTheme.PopupOverlay" />

        <LinearLayout
            android:id="@+id/layProgresoDatos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:text="Grabando clientes"
                android:textSize="@dimen/text_actionbar_small"
                android:textStyle="bold"
                android:textColor="@color/textoBlanco"
                android:layout_centerVertical="true"
                android:layout_centerHorizontal="true"
                android:layout_marginRight="10dp"
                android:layout_weight="3"
                android:layout_gravity="center_vertical"/>

            <ProgressBar
                android:id="@+id/pbProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="15dp"
                android:layout_marginRight="20dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="82"
                android:layout_centerHorizontal="true"
                android:layout_weight="5"/>


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="horizontal"
            android:layout_marginBottom="5dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivAplicaPension"
                android:layout_width="@dimen/icon_small_size"
                android:layout_height="@dimen/icon_small_size"
                android:background="@drawable/pension_no"
                android:layout_marginLeft="15dp"/>

            <TextView
                android:id="@+id/tvBarPension"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:layout_weight="3"
                android:gravity="start"

                android:text="DESAYUNO(SD)"
                android:textColor="@color/verde"
                android:textSize="@dimen/text_actionbar"

                android:textStyle="bold" />



            <TextView
                android:id="@+id/tvLatencia"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:text="ws: 350/1250 ms"
                android:textSize="@dimen/text_actionbar"
                android:textStyle="bold"
                android:textColor="@color/verde"
                android:layout_centerVertical="true"
                android:gravity="end"
                android:layout_marginRight="10dp"
                android:layout_weight="3"
                android:layout_gravity="center_vertical"/>


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="@dimen/icon_small_size"
                android:layout_height="@dimen/icon_small_size"
                android:visibility="gone"
                android:background="@drawable/bar_user" />

            <TextView
                android:id="@+id/tvBarUser"
                android:layout_width="wrap_content"
                android:minWidth="80dp"
                android:layout_height="wrap_content"
                android:text="@string/bar_user"
                android:textSize="@dimen/text_actionbar"
                android:textColor="@color/textoBlanco"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="15dp"
                android:visibility="gone"
                />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="@dimen/icon_small_size"
                android:layout_height="@dimen/icon_small_size"
                android:background="@drawable/bar_tpv"
                android:visibility="gone"
                android:layout_marginLeft="15dp"/>

            <TextView
                android:id="@+id/tvBarTpv"
                android:layout_width="wrap_content"
                android:minWidth="80dp"
                android:layout_height="wrap_content"
                android:text="@string/bar_tpv"
                android:textSize="@dimen/text_actionbar"
                android:textColor="@color/textoBlanco"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="15dp"
                android:visibility="gone"
                />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="@dimen/icon_small_size"
                android:layout_height="@dimen/icon_small_size"
                android:background="@drawable/bar_mesa"
                android:layout_marginLeft="15dp"/>


            <TextView
                android:id="@+id/tvBarMesa"
                android:layout_width="wrap_content"
                android:minWidth="80dp"
                android:layout_height="wrap_content"
                android:text="@string/bar_mesa"
                android:textSize="@dimen/text_actionbar"
                android:textColor="@color/textoBlanco"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="15dp"
                />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivBarPax"
                android:layout_width="@dimen/icon_small_size"
                android:layout_height="@dimen/icon_small_size"
                android:background="@drawable/bar_pax"
                android:layout_marginLeft="15dp"/>


            <TextView
                android:id="@+id/tvBarPax"
                android:layout_width="wrap_content"
                android:minWidth="80dp"
                android:layout_height="wrap_content"
                android:text="@string/bar_pax"
                android:textSize="@dimen/text_actionbar"
                android:textColor="@color/textoBlanco"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="15dp"
                />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivBarRoom"
                android:layout_width="@dimen/icon_small_size"
                android:layout_height="@dimen/icon_small_size"
                android:background="@drawable/bar_room"
                android:layout_marginLeft="15dp"/>


            <TextView
                android:id="@+id/tvBarRoom"
                android:layout_width="wrap_content"
                android:minWidth="80dp"
                android:layout_height="wrap_content"
                android:text="@string/bar_habitacion"
                android:textSize="@dimen/text_actionbar"
                android:textColor="@color/textoBlanco"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="15dp"
                />


        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <include layout="@layout/ini_content_activity_inicio" />


</androidx.coordinatorlayout.widget.CoordinatorLayout>
