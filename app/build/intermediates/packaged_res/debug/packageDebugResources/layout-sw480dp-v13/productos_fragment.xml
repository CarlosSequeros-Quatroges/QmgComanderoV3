<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layCons"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/layFiltos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        >
        <androidx.appcompat.widget.SearchView
            android:id="@+id/svProductos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            tools:layout_editor_absoluteX="8dp"
            tools:layout_editor_absoluteY="315dp"
            android:inputType="text"
            android:background="@color/cvFondo"
            android:layout_weight="10"
            />
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivFiltros"
            android:layout_width="@dimen/icon_size"
            android:layout_height="@dimen/icon_size"
            android:background="@drawable/bar_filtrar"
            android:layout_marginHorizontal="10dp"
            android:layout_gravity="center_vertical"
            />
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivOrden"
            android:layout_width="@dimen/icon_size"
            android:layout_height="@dimen/icon_size"
            android:background="@drawable/bar_filtro_az"
            android:layout_marginHorizontal="10dp"
            android:layout_gravity="center_vertical"
            />

    </LinearLayout>


    <LinearLayout
        android:id="@+id/layUnidades"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/textoAzul"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvUnidades"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:maxLines="2"
            android:minLines="1"
            android:text="Comanda: 12  Unidades"
            android:textColor="@color/textoBlanco"
            android:textSize="@dimen/text_titulo2"
            android:textStyle="bold"
            android:layout_marginLeft="@dimen/icon_small_size"
            android:paddingVertical="5dp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/flMin"
            android:layout_width="@dimen/icon_small_size"
            android:layout_height="wrap_content"
            >

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivMin"
                android:layout_width="@dimen/icon_cv_size"
                android:layout_height="@dimen/icon_cv_size"
                android:background="@drawable/arrow"
                android:layout_gravity="top"
                android:rotation="90"
                android:alpha=".4"
                />

        </FrameLayout>

        <androidx.recyclerview.widget.RecyclerView
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:tools="http://schemas.android.com/tools"
            android:id="@+id/rvProductos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:paddingBottom="?attr/actionBarSize"
            android:clipToPadding="false"
            android:clipChildren="false"

            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            tools:itemCount="10"
            tools:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            tools:listitem="@layout/productos_cardview"
            tools:orientation="horizontal"
            tools:spanCount="2"
            android:layout_marginBottom="50dp"
            android:layout_weight="50"/>

        <LinearLayout
            android:id="@+id/flMax"
            android:layout_width="@dimen/icon_size"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            >

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivMax"
                android:layout_width="@dimen/icon_cv_size"
                android:layout_height="@dimen/icon_cv_size"
                android:layout_gravity="top|right"
                android:layout_marginBottom="5dp"
                android:alpha=".4"
                android:background="@drawable/arrow"
                android:rotation="-90" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivVerMas"
                android:layout_width="@dimen/icon_size"
                android:layout_height="@dimen/icon_size"
                android:layout_gravity="bottom"
                android:background="@drawable/arrow"
                android:rotation="0" />


        </LinearLayout>


    </LinearLayout>

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@color/categoria_sel"
        />
</LinearLayout>


