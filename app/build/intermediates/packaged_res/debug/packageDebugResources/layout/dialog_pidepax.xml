<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical">



    <LinearLayout
        android:id="@+id/layNewPax"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/layNewPax_room"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="left"
            android:layout_marginHorizontal="20dp"
            android:layout_marginVertical="10dp"
            android:text="@string/dialog_strRoomAñadir"
            android:textColor="@color/textoAzul"
            android:textSize="@dimen/text_titulo"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:layout_marginLeft="20dp">


            <EditText
                android:id="@+id/etRoom"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:paddingVertical="15dp"
                android:text=""
                android:hint="@string/dialog_strHintHabitacion"
                android:textStyle="bold"
                android:textSize="@dimen/text_titulo"
                android:textColor="@color/colorAccent"
                android:gravity="center_horizontal"
                android:selectAllOnFocus="true"
                android:inputType="text"

                />

        </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layNewPax_pax"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="left"
            android:layout_marginHorizontal="20dp"
            android:layout_marginVertical="10dp"
            android:text="@string/dialog_strPaxAñadir"
            android:textColor="@color/textoAzul"
            android:textSize="@dimen/text_titulo"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:layout_marginLeft="20dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivPaxDown"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical"
                android:background="@drawable/quitar" />


            <EditText
                android:id="@+id/etPax"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:paddingVertical="15dp"
                android:text="12"
                android:hint="@string/dialog_strHintPax"
                android:textStyle="bold"
                android:textSize="@dimen/text_titulo"
                android:textColor="@color/colorAccent"
                android:gravity="center_horizontal"
                android:selectAllOnFocus="true"
                android:inputType="number"

                />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivPaxUp"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical"
                android:background="@drawable/anadir" />

        </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/textoAzul"
        android:layout_marginVertical="10dp"/>

    <LinearLayout
        android:id="@+id/layMovePax"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:layout_marginLeft="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="left|center_vertical"
            android:text="@string/dialog_strPaxMover"
            android:textStyle="bold"
            android:textColor="@color/textoAzul"
            android:textSize="@dimen/text_titulo"/>


        <TextView
            android:id="@+id/tvPaxMover"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:text="12"
            android:hint="@string/dialog_strHintPax"
            android:textStyle="bold"
            android:textSize="@dimen/text_titulo"
            android:textColor="@color/colorAccent"
            android:gravity="center_horizontal"

            />


    </LinearLayout>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSubmesas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="5dp"
        tools:itemCount="8"
        tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/submesas_pax_cardview"
        tools:spanCount="2"
        tools:orientation="vertical"
        />
</LinearLayout>