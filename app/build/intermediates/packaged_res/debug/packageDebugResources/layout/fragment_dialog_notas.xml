<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsvNotas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:text="Notas:"
                android:textColor="@color/textoAzul"
                android:textSize="@dimen/text_titulo"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/textoAzul" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvNotas"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="6dp"
                android:orientation="vertical"
                android:paddingHorizontal="3dp"
                tools:itemCount="6"
                tools:listitem="@layout/notas_cardview"
                tools:orientation="vertical" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                android:text="Texto nota:"
                android:textColor="@color/textoAzul"
                android:textSize="@dimen/text_titulo2"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layAccionesNota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_horizontal"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivAnadirNota"
                    android:layout_width="@dimen/icon_size"
                    android:layout_height="@dimen/icon_size"
                    android:layout_marginHorizontal="10dp"
                    android:background="@drawable/bar_submesa_add" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivAceptarNota"
                    android:layout_width="@dimen/icon_size"
                    android:layout_height="@dimen/icon_size"
                    android:layout_marginHorizontal="10dp"
                    android:background="@drawable/aceptar" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivCancelarNota"
                    android:layout_width="@dimen/icon_size"
                    android:layout_height="@dimen/icon_size"
                    android:layout_marginHorizontal="10dp"
                    android:background="@drawable/cancelar" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivBorrarNota"
                    android:layout_width="@dimen/icon_size"
                    android:layout_height="@dimen/icon_size"
                    android:layout_marginHorizontal="10dp"
                    android:background="@drawable/bar_eliminar" />
            </LinearLayout>


            <EditText
                android:id="@+id/etNota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/fondoFrgDetalleNota2"
                android:fadeScrollbars="false"
                android:gravity="top|left"
                android:hint="Escribe una nota..."
                android:imeOptions="flagNoExtractUi"
                android:inputType="textMultiLine"
                android:maxLines="6"
                android:minLines="4"
                android:padding="10dp"
                android:scrollbars="vertical"
                android:textColor="@color/negro"
                android:textSize="@dimen/text_titulo" />
        </LinearLayout>



    </androidx.core.widget.NestedScrollView>



</LinearLayout>
