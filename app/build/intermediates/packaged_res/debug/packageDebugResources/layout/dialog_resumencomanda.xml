<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorAccent"
        android:paddingVertical="5dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="left"
            android:text="@string/dialog_strUds"
            android:textColor="@color/textoBlanco"
            android:textSize="@dimen/text_titulo"
            android:textStyle="bold"
            android:layout_weight="25"
            android:gravity="center"
            />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="left"
            android:text="@string/dialog_strDescripcion"
            android:textStyle="bold"
            android:textColor="@color/textoBlanco"
            android:textSize="@dimen/text_titulo"
            android:layout_weight="80"
            android:gravity="center"
            />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="left"
            android:text="@string/dialog_strPVP"
            android:textStyle="bold"
            android:textColor="@color/textoBlanco"
            android:textSize="@dimen/text_titulo"
            android:layout_weight="25"
            />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="left"
            android:text="@string/dialog_strImporte"
            android:textStyle="bold"
            android:textColor="@color/textoBlanco"
            android:textSize="@dimen/text_titulo"
            android:layout_weight="25"
            />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorAccent"
        android:orientation="horizontal"
        android:paddingBottom="5dp">

        <TextView
            android:id="@+id/tvUds"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="left"
            android:text="1"
            android:textColor="@color/textoBlanco"
            android:textSize="@dimen/text_titulo"
            android:textStyle="bold"
            android:gravity="right"
            android:layout_weight="25"
            android:paddingRight="5dp"
            />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="left"
            android:text=""
            android:textStyle="bold"
            android:textColor="@color/textoBlanco"
            android:textSize="@dimen/text_titulo"
            android:layout_weight="80"
            />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="left"
            android:text="@string/dialog_strTotal"
            android:textStyle="bold"
            android:textColor="@color/textoBlanco"
            android:textSize="@dimen/text_titulo"
            android:layout_weight="25"
            />
        <TextView
            android:id="@+id/tvTotal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="left"
            android:text="10,50"
            android:textStyle="bold"
            android:textColor="@color/textoBlanco"
            android:textSize="@dimen/text_titulo"
            android:layout_weight="25"

            />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLineaVentas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="0dp"
        tools:itemCount="5"
        tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/resumenlineaventas_cardview"
        tools:orientation="vertical"
        tools:spanCount="1" />


</LinearLayout>