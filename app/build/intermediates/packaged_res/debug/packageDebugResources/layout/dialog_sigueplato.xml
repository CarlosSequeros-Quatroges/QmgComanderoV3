<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/layOrdenPlatos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="horizontal"
        android:layout_marginVertical="40dp"
        >
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivBebida"
            android:layout_width="@dimen/icon_size"
            android:layout_height="@dimen/icon_size"
            android:background="@drawable/bar_bebida_sel"
            android:layout_gravity="center_horizontal"
            />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivEntrante"
            android:layout_width="@dimen/icon_size"
            android:layout_height="@dimen/icon_size"
            android:background="@drawable/bar_entrante_sel"
            android:layout_gravity="center_horizontal"
            android:layout_marginLeft="30dp"
            />
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivPrimero"
            android:layout_width="@dimen/icon_size"
            android:layout_height="@dimen/icon_size"
            android:background="@drawable/bar_primero_sel"
            android:layout_gravity="center_horizontal"
            android:layout_marginLeft="30dp"
            />
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivSegundo"
            android:layout_width="@dimen/icon_size"
            android:layout_height="@dimen/icon_size"
            android:background="@drawable/bar_comida_sel"
            android:layout_gravity="center_horizontal"
            android:layout_marginLeft="30dp"
            />
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivPostre"
            android:layout_width="@dimen/icon_size"
            android:layout_height="@dimen/icon_size"
            android:background="@drawable/bar_postre_sel"
            android:layout_gravity="center_horizontal"
            android:layout_marginLeft="30dp"
            />


    </LinearLayout>




</LinearLayout>