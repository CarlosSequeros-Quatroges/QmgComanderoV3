<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layout_margin="10dp"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/textoAzul"
        android:gravity="start"
        android:padding="10dp"
        android:text="Pensión:"
        android:textColor="@color/textoBlanco"
        android:textStyle="bold"
        android:textSize="@dimen/text_titulo2"
        android:layout_weight="8"
        android:layout_marginHorizontal="2dp"
        />

    <TextView
        android:id="@+id/tvPension"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/textoAzul"
        android:gravity="center"
        android:padding="10dp"
        android:text="MP"
        android:textColor="@color/textoBlanco"
        android:textStyle="italic"
        android:textSize="@dimen/text_titulo2"
        android:layout_weight="8"
        android:layout_marginHorizontal="2dp"
        />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/textoAzul"
        android:gravity="start"
        android:padding="10dp"
        android:text="Tipo de pensión:"
        android:textColor="@color/textoBlanco"
        android:textStyle="bold"
        android:textSize="@dimen/text_titulo2"
        android:layout_weight="8"
        android:layout_marginHorizontal="2dp"
        />


    <TextView
        android:id="@+id/tvTipoPension"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/textoAzul"
        android:gravity="center"
        android:padding="10dp"
        android:text="MP"
        android:textColor="@color/textoBlanco"
        android:textStyle="italic"
        android:textSize="@dimen/text_titulo2"
        android:layout_weight="8"
        android:layout_marginHorizontal="2dp"
        />

    <TextView
        android:id="@+id/tvHoraApertura"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/textoAzul"
        android:gravity="start"
        android:padding="10dp"
        android:text="Hora inicio comanda"
        android:textColor="@color/textoBlanco"
        android:textStyle=""
        android:textSize="@dimen/text_titulo2"
        android:layout_weight="8"
        android:layout_marginHorizontal="2dp"
        />

    <TextView
        android:id="@+id/tvAplicaPension"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/textoAzul"
        android:gravity="start"
        android:padding="10dp"
        android:text="Aplica pensión"
        android:textColor="@color/textoBlanco"
        android:textStyle=""
        android:textSize="@dimen/text_titulo2"
        android:layout_weight="8"
        android:layout_marginHorizontal="2dp"
        />

    <TextView
        android:id="@+id/tvPensionAplicada"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/textoAzul"
        android:gravity="start"
        android:padding="10dp"
        android:text="Pase"
        android:textColor="@color/textoBlanco"
        android:textStyle=""
        android:textSize="@dimen/text_titulo2"
        android:layout_weight="8"
        android:layout_marginHorizontal="2dp"
        />

    <TextView
        android:id="@+id/tvHorarioAplicado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/textoAzul"
        android:gravity="start"
        android:padding="10dp"
        android:text="Horario"
        android:textColor="@color/textoBlanco"
        android:textStyle=""
        android:textSize="@dimen/text_titulo2"
        android:layout_weight="8"
        android:layout_marginHorizontal="2dp"
        />


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/textoAzul"
        android:gravity="start"
        android:padding="10dp"
        android:text="Horarios:"
        android:textColor="@color/textoBlanco"
        android:textStyle="bold"
        android:textSize="@dimen/text_titulo2"
        android:layout_weight="8"
        android:layout_marginHorizontal="2dp"
        />


    <TextView
        android:id="@+id/tvHorarioDesayuno"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/textoAzul"
        android:gravity="start"
        android:padding="5dp"
        android:text="00:00  - 00:00"
        android:paddingStart="30dp"
        android:textColor="@color/textoBlanco"
        android:textStyle="italic"
        android:textSize="@dimen/text_titulo2"
        android:layout_weight="8"
        android:layout_marginHorizontal="2dp"
        />

    <TextView
        android:id="@+id/tvHorarioAlmuerzo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/textoAzul"
        android:gravity="start"
        android:padding="5dp"
        android:paddingStart="30dp"
        android:text="00:00  - 00:00"
        android:textColor="@color/textoBlanco"
        android:textStyle="italic"
        android:textSize="@dimen/text_titulo2"
        android:layout_weight="8"
        android:layout_marginHorizontal="2dp"
        />

    <TextView
        android:id="@+id/tvHorarioCena"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/textoAzul"
        android:gravity="start"
        android:padding="5dp"
        android:paddingStart="30dp"
        android:text="00:00  - 00:00"
        android:textColor="@color/textoBlanco"
        android:textStyle="italic"
        android:textSize="@dimen/text_titulo2"
        android:layout_weight="8"
        android:layout_marginHorizontal="2dp"
        />


</LinearLayout>


